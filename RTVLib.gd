extends Node

# RTVModLib - Godot 4 Mod Framework Hook Library
# Auto-generated - do not edit manually

var _hooks: Dictionary = {}
var _next_id: int = 1
var _skip_super: bool = false
var _seq: int = 0

func _ready():
	Engine.set_meta("RTVModLib", self)
	print("RTVModLib: Loaded")

## Call from a replace hook to prevent the original method from running
func skip_super():
	_skip_super = true

## Register a hook. Returns a hook ID for removal, or -1 if rejected.
## hook_name examples:
##   "interface-open-pre"       - runs before original (stackable)
##   "interface-open-post"      - runs after original (stackable)
##   "interface-open-callback"  - deferred after original (stackable)
##   "interface-open"           - REPLACE the original (first-wins, only one allowed)
## callback: Callable to invoke
## priority: lower = runs first (default 100). Ignored for replace hooks.
func hook(hook_name: String, callback: Callable, priority: int = 100) -> int:
	var is_replace = !(hook_name.ends_with("-pre") or hook_name.ends_with("-post") or hook_name.ends_with("-callback"))
	if is_replace and _hooks.has(hook_name) and _hooks[hook_name].size() > 0:
		var owner_id = _hooks[hook_name][0]["id"]
		push_warning("RTVModLib: replace hook '" + hook_name + "' already owned (id=" + str(owner_id) + "), registration rejected")
		return -1
	if !_hooks.has(hook_name):
		_hooks[hook_name] = []
	var entry = {"callback": callback, "priority": priority, "id": _next_id}
	_hooks[hook_name].append(entry)
	_hooks[hook_name].sort_custom(func(a, b): return a["priority"] < b["priority"])
	var id = _next_id
	_next_id += 1
	return id

## Remove a hook by ID
func unhook(hook_id: int):
	for hook_name in _hooks:
		var arr: Array = _hooks[hook_name]
		for i in range(arr.size() - 1, -1, -1):
			if arr[i]["id"] == hook_id:
				arr.remove_at(i)
				return

## Check if any hooks are registered
func has_hooks(hook_name: String) -> bool:
	return _hooks.has(hook_name) and _hooks[hook_name].size() > 0

## Check if a replace hook is currently registered for a method.
## hook_name is the bare method hook (no -pre/-post/-callback suffix),
## e.g. "lootcontainer-interact".
func has_replace(hook_name: String) -> bool:
	return _hooks.has(hook_name) and _hooks[hook_name].size() > 0

## Get the hook ID of the current replace owner, or -1 if none.
## Useful for a mod to detect an existing replace before attempting its own
## registration, so it can fall back to pre/post or refuse to load cleanly.
func get_replace_owner(hook_name: String) -> int:
	if !_hooks.has(hook_name) or _hooks[hook_name].size() == 0:
		return -1
	return _hooks[hook_name][0]["id"]

# --- Internal dispatch ---

func _dispatch(hook_name: String, args: Array):
	if !_hooks.has(hook_name):
		return
	for entry in _hooks[hook_name]:
		_seq += 1
		var cb: Callable = entry["callback"]
		cb.callv(args)

func _dispatch_deferred(hook_name: String, args: Array):
	if !_hooks.has(hook_name):
		return
	for entry in _hooks[hook_name]:
		_seq += 1
		var cb: Callable = entry["callback"]
		cb.bindv(args).call_deferred()

## Public: current global dispatch sequence number (for test/debug logging)
func seq() -> int:
	return _seq

func _get_hooks(hook_name: String) -> Array:
	if !_hooks.has(hook_name):
		return []
	var callbacks = []
	for entry in _hooks[hook_name]:
		callbacks.append(entry["callback"])
	return callbacks

